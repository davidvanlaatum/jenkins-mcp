{
  "defaultController": "default",
  "controllers": [
    {
      "id": "default",
      "url": "https://jenkins.example.com",
      "username": "your-user",
      "token": "your-api-token"
    }
  ],
  "mutations": {
    "enabled": false
  },
  "limits": {
    "maxResponseBytes": 65536,
    "logChunkBytes": 65536,
    "inlineBytes": 32768
  },
  "watch": {
    "pollIntervalMs": 3000,
    "defaultWaitTimeoutMs": 120000,
    "maxWaitTimeoutMs": 900000,
    "maxConsecutiveFailures": 3
  },
  "artifacts": {
    "downloadDir": "/tmp/jenkins-mcp-artifacts"
  },
  "audit": {
    "path": ""
  },
  "updates": {
    "enabled": true,
    "repository": "davidvanlaatum/jenkins-mcp",
    "checkIntervalHours": 24
  },
  "capabilities": {
    "pluginDiscoveryEnabled": true
  }
}
